# Server
PORT=3000

# Lark / Feishu API Credentials
# Create an app at https://open.feishu.cn/app (Feishu) or https://open.larksuite.com/app (Lark International)
LARK_APP_ID=your_app_id_here
LARK_APP_SECRET=your_app_secret_here

# Lark Base (Bitable) Configuration
# Open your Lark Base, the app_token is in the URL: https://xxx.feishu.cn/base/{app_token}
LARK_APP_TOKEN=your_base_app_token_here

# Table IDs — found in each table's URL or via API
# Create 3 tables in your Lark Base: Volunteers, Membership, Sponsors
LARK_TABLE_VOLUNTEER=your_volunteer_table_id
LARK_TABLE_MEMBERSHIP=your_membership_table_id
LARK_TABLE_SPONSOR=your_sponsor_table_id

# API Domain (uncomment the one you need)
# For Feishu (China):
LARK_API_DOMAIN=https://open.feishu.cn
# For Lark (International):
# LARK_API_DOMAIN=https://open.larksuite.com
